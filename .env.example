# ============================================================
# 艺育皮韵 (Leather Carving Education Platform)
# Environment Variables Template
# Copy to .env.development / .env.production and fill in values
# ============================================================

# ---- Application ----
APP_NAME=艺育皮韵
APP_URL=http://localhost:3000
API_URL=http://localhost:3001/api/v1
NODE_ENV=development
PORT=3001

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=艺育皮韵
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ---- Database (PostgreSQL) ----
DB_USER=lc_user
DB_PASSWORD=your-db-password-here
DB_NAME=leather_carving
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT Authentication ----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ---- Object Storage (MinIO) ----
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=leather-carving
MINIO_USE_SSL=false

# ---- AI Service ----
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Production-only (used by docker-compose.prod.yml) ----
# HTTP_PORT=80
# HTTPS_PORT=443
# MINIO_CONSOLE_PORT=9000
# MINIO_API_PORT=9001
