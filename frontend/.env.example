# ============================================================
# 艺育皮韵 - 前端环境变量配置模板
# 复制此文件为 .env.local 并填入实际值
# cp .env.example .env.local
# ============================================================

# ─────────────────────────────────────────────
# 后端 API 地址 - 必需
# ─────────────────────────────────────────────

# 后端 API 的完整基础 URL (含 /api/v1 路径前缀)
# 本地开发: http://localhost:3001/api/v1
# 分开部署: https://api.your-domain.com/api/v1
# Docker 部署: 留空即可, 通过 Nginx 反代自动处理
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─────────────────────────────────────────────
# WebSocket 连接地址 - 可选
# ─────────────────────────────────────────────

# WebSocket 服务器地址 (用于实时通知)
# 不设置时自动从 NEXT_PUBLIC_API_URL 推导 (去掉 /api/v1 后缀)
# 本地开发: ws://localhost:3001
# 分开部署: wss://api.your-domain.com
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─────────────────────────────────────────────
# 应用信息 - 可选
# ─────────────────────────────────────────────

# 应用名称 (显示在浏览器标题等位置)
NEXT_PUBLIC_APP_NAME=艺育皮韵
