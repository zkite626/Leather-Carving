# ============================================================
# 艺育皮韵 - 后端环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# ─────────────────────────────────────────────
# 应用基础配置
# ─────────────────────────────────────────────

# 应用运行端口
PORT=3001

# 运行环境: development | production | test
NODE_ENV=development

# ─────────────────────────────────────────────
# 数据库 (PostgreSQL) - 必需
# ─────────────────────────────────────────────

# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL=postgresql://lc_user:lc_password@localhost:5455/leather_carving?schema=public

# ─────────────────────────────────────────────
# JWT 认证 - 必需
# ─────────────────────────────────────────────

# JWT 密钥 (生产环境务必更换为强随机字符串)
# 可使用命令生成: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Access Token 过期时间 (如: 15m, 1h, 2h, 1d)
JWT_ACCESS_EXPIRES_IN=2h

# Refresh Token 过期时间 (如: 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# 跨域配置 - 必需
# ─────────────────────────────────────────────

# 允许的前端域名 (多个用逗号分隔, 如: http://localhost:3000,https://your-domain.com)
# 前后端分开部署时，此处填写前端实际部署地址
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────
# Redis - 可选 (不配置则自动降级为内存缓存)
# ─────────────────────────────────────────────

# Redis 主机地址 (不设置此项则跳过 Redis, 使用内存缓存)
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码 (无密码留空)
REDIS_PASSWORD=

# 降级说明:
# - 未配置 REDIS_HOST 时, AI 聊天历史将存储在内存中 (重启丢失)
# - Redis 连接失败时, 系统会自动降级为内存模式, 不影响其他功能

# ─────────────────────────────────────────────
# 文件存储 (MinIO) - 可选 (不配置则使用本地磁盘存储)
# ─────────────────────────────────────────────

# MinIO 服务地址 (不设置此项则使用本地磁盘存储)
MINIO_ENDPOINT=localhost

# MinIO API 端口
MINIO_PORT=9000

# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin

# MinIO 密钥
MINIO_SECRET_KEY=minioadmin

# 是否使用 SSL 连接 MinIO
MINIO_USE_SSL=false

# MinIO 公开访问 URL (用于生成文件链接, 通常与 MINIO_ENDPOINT:MINIO_PORT 一致)
# 如果前面配置了 Nginx 反代 MinIO, 此处填写反代地址
MINIO_PUBLIC_URL=http://localhost:9000

# 本地存储目录 (仅在未配置 MINIO_ENDPOINT 时生效)
LOCAL_UPLOAD_DIR=uploads

# 降级说明:
# - 未配置 MINIO_ENDPOINT 时, 文件将存储到本地磁盘 uploads/ 目录
# - 本地存储模式下, 文件通过 /uploads/ 路径访问
# - 本地存储适合开发和小规模部署, 生产环境建议使用 MinIO 或兼容 S3 的服务

# ─────────────────────────────────────────────
# AI 服务 - 可选 (不配置则 AI 功能不可用)
# ─────────────────────────────────────────────

# AI 功能需要在管理后台 -> AI 管理 中配置模型后才可使用
# 此处仅设置默认值, 实际配置存储在数据库中

# 默认 AI 提供商 (仅作为管理后台的默认值提示)
AI_DEFAULT_PROVIDER=openai

# 默认 AI 模型名称 (仅作为管理后台的默认值提示)
AI_DEFAULT_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# Swagger API 文档
# ─────────────────────────────────────────────

# Swagger 文档路径 (默认: /api/docs)
# 生产环境建议禁用, 通过 NODE_ENV=production 自动隐藏
# SWAGGER_PATH=api/docs

# ─────────────────────────────────────────────
# SMTP 邮件服务 - 可选 (不配置则邮件功能不可用)
# SMTP 配置通过管理后台 -> 系统配置 -> SMTP 配置 进行管理
# 此处仅作为环境变量备选, 管理后台配置优先
# ─────────────────────────────────────────────

# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your-email@qq.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=your-email@qq.com
# SMTP_FROM_NAME=艺育皮韵
# SMTP_ENCRYPTION=ssl
